generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Administrador {
  id             Int        @id @default(autoincrement())
  nombre         String     @db.VarChar(100)
  email          String     @unique @db.VarChar(150)
  password_hash  String     @db.VarChar(255)
  rol            String?    @default("gestor_productos") @db.VarChar(50)
  fecha_registro DateTime?  @default(now()) @db.Timestamp(6)
  productos      Producto[]

  @@map("administradores")
}

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String     @db.VarChar(100)
  descripcion String?
  productos   Producto[]

  @@map("categorias")
}

model Usuario {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(100)
  apellido       String    @db.VarChar(100)
  email          String    @unique @db.VarChar(150)
  password_hash  String    @db.VarChar(255)
  telefono       String?   @db.VarChar(20)
  direccion      String?   @db.VarChar(255)
  fecha_registro DateTime? @default(now()) @db.Timestamp(6)
  estado         String?   @default("activo") @db.VarChar(20)
  carritos       Carrito[]
  pedidos        Pedido[]

  @@map("usuarios")
}

model Producto {
  id                  Int              @id @default(autoincrement())
  nombre              String           @db.VarChar(150)
  descripcion         String?
  precio_original     Decimal          @db.Decimal(10, 2)
  precio_descuento    Decimal?         @db.Decimal(10, 2)
  cantidad_disponible Int              @default(0)
  fecha_vencimiento   DateTime         @db.Date
  fecha_publicacion   DateTime?        @default(now()) @db.Timestamp(6)
  imagen_url          String?          @db.VarChar(255)
  estado              String?          @default("disponible") @db.VarChar(20)
  categoria_id        Int?
  administrador_id    Int?
  carrito_detalle     CarritoDetalle[]
  ofertas_especiales  OfertaEspecial[]
  pedido_detalle      PedidoDetalle[]
  administradores     Administrador?   @relation(fields: [administrador_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categorias          Categoria?       @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("productos")
}

model OfertaEspecial {
  id                   Int       @id @default(autoincrement())
  producto_id          Int?
  porcentaje_descuento Decimal   @db.Decimal(5, 2)
  fecha_inicio         DateTime  @db.Timestamp(6)
  fecha_fin            DateTime  @db.Timestamp(6)
  estado               String?   @default("activa") @db.VarChar(20)
  productos            Producto? @relation(fields: [producto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("ofertas_especiales")
}

model Carrito {
  id              Int              @id @default(autoincrement())
  usuario_id      Int?
  fecha_creacion  DateTime?        @default(now()) @db.Timestamp(6)
  estado          String?          @default("activo") @db.VarChar(20)
  carrito_detalle CarritoDetalle[]
  usuarios        Usuario?         @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("carritos")
}

model CarritoDetalle {
  id              Int       @id @default(autoincrement())
  carrito_id      Int?
  producto_id     Int?
  cantidad        Int       @default(1)
  precio_unitario Decimal   @db.Decimal(10, 2)
  carritos        Carrito?  @relation(fields: [carrito_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productos       Producto? @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("carrito_detalle")
}

model Pedido {
  id                     Int             @id @default(autoincrement())
  usuario_id             Int?
  fecha_pedido           DateTime?       @default(now()) @db.Timestamp(6)
  fecha_entrega_estimada DateTime?       @db.Timestamp(6)
  direccion_entrega      String?         @db.VarChar(255)
  metodo_pago            String?         @db.VarChar(50)
  estado                 String?         @default("pendiente") @db.VarChar(20)
  total                  Decimal         @db.Decimal(10, 2)
  pedido_detalle         PedidoDetalle[]
  usuarios               Usuario?        @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("pedidos")
}

model PedidoDetalle {
  id              Int       @id @default(autoincrement())
  pedido_id       Int?
  producto_id     Int?
  cantidad        Int
  precio_unitario Decimal   @db.Decimal(10, 2)
  subtotal        Decimal   @db.Decimal(10, 2)
  pedidos         Pedido?   @relation(fields: [pedido_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productos       Producto? @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("pedido_detalle")
}
